{
  "apiVersion": 3,
  "name": "badegg/masthead",
  "title": "Article Masthead",
  "category": "text",
  "icon": {
    "src": "edit",
    "foreground": "#f58762"
  },
  "description": "Display the title, categories, and date.",
  "keywords": ["title", "author", "category", "meta"],
  "supports": {
    "html": true,
    "multiple": false,
    "color": {
      "background": false,
      "text": false
    }
  },
  "attributes": {
    "titlePrefix": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "hideTitlePrefix": {
      "type": "boolean",
      "default": false
    },
    "hideCategories": {
      "type": "boolean",
      "default": false
    },
    "hideDate": {
      "type": "boolean",
      "default": false
    },
    "hideSubtitle": {
      "type": "boolean",
      "default": false
    }
  }
}
